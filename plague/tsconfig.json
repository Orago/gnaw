{
	"compilerOptions": {
		"target": "ES2022",
		"lib": [
			"ES5",
			"DOM",
			"ES2021"
		],
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"baseUrl": "./lib",
		"types": [
			"node"
		],
		"declaration": true,
		"resolveJsonModule": true,
		"allowJs": true,
		"outDir": "./dist/",
		"rootDir": "./lib/",
		"removeComments": true,
		"allowSyntheticDefaultImports": true,
		// "esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"strictPropertyInitialization": false,
	},
	"watchOptions": {
		"excludeDirectories": [
			"**/node_modules"
		]
	},
	"include": [
		"lib/**/*"
	],
	"exclude": [
		"node_modules"
	]
}